rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Logos de barberías: solo admin puede subir
    match /logos/{barberiaId}/{fileName} {
      allow read: if true; // Público para mostrar en landing
      allow write: if request.auth != null &&
        request.auth.token.role == "admin" &&
        request.auth.token.barberia_id == barberiaId;
    }

    // Archivos de barbería (documentos, etc.)
    match /barberias/{barberiaId}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.token.barberia_id == barberiaId;
      allow write: if request.auth != null &&
        request.auth.token.role == "admin" &&
        request.auth.token.barberia_id == barberiaId;
    }

    // Assets públicos del Super Admin
    match /public/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.token.role == "superadmin";
    }
  }
}